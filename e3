from keras.applications.vgg16 import VGG16
import matplotlib.pyplot as plt

model = VGG16()

filters, biases = model.layers[1].get_weights()

f_min, f_max = filters.min(), filters.max()
filters = (filters - f_min)/ (f_max - f_min)

n_filters , ix = 6, 1

for i in range(n_filters):
   f = filters[:,:,:,i]
   for j in range(3):
      ax = plt.subplot(n_filters, 3, ix)
      ax.set_xticks([]);  ax.set_yticks([])
      plt.imshow(f[:,:,j], cmap='gray')
      ix += 1
plt.show()

#### plot 64 feature maps
from keras.applications.vgg16 import VGG16, preprocess_input
from keras.preprocessing.image import load_img, img_to_array
from keras.models import Model
from matplotlib import pyplot as plt
import numpy as np

# Load model and redefine output (first conv layer)
base_model = VGG16()
model = Model(inputs=base_model.input, outputs=base_model.layers[1].output)

# Load and preprocess image
img = load_img('bird.jpg', target_size=(224, 224))
img = preprocess_input(np.expand_dims(img_to_array(img), axis=0))

# Get feature maps
feature_maps = model.predict(img)

# Plot 64 feature maps (8x8 grid)
for i in range(64):
    plt.subplot(8, 8, i + 1)
    plt.imshow(feature_maps[0, :, :, i], cmap='gray')
    plt.axis('off')

plt.show()

#### multi-layer feature map
from keras.applications.vgg16 import VGG16, preprocess_input
from keras.preprocessing.image import load_img, img_to_array
from keras.models import Model
from matplotlib import pyplot as plt
import numpy as np

# Load model and extract selected layers
base = VGG16()
model = Model(inputs=base.input,
              outputs=[base.layers[i].output for i in [2, 5, 9, 13, 17]])

# Load & preprocess image
img = load_img('D:/OCT/bird.jpg', target_size=(224, 224))
img = preprocess_input(np.expand_dims(img_to_array(img), axis=0))

# Predict feature maps
feature_maps = model.predict(img)

# Plot feature maps
for fmap in feature_maps:
    for i in range(64):
        plt.subplot(8, 8, i + 1)
        plt.imshow(fmap[0, :, :, i], cmap='gray')
        plt.axis('off')
    plt.show()


