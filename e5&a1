from tf_explain.core.grad_cam import GradCAM
def grad_CAM(image_path):
    img = cv2.imread(image_path)
    img = cv2.resize(img, (299, 299))
    plt.imshow(img)
    plt.axis('off')
    plt.show()

    x = img / 255.0   # or use preprocess_input if used in training
    x = np.expand_dims(x, axis=0)

    explainer = GradCAM()

    grid = explainer.explain(
        validation_data=(x, np.array([0])),
        model=model,
        layer_name="conv2d_93",  # make sure this layer exists
        class_index=None
    )

    plt.imshow(grid)
    plt.axis('off')
    plt.show()

