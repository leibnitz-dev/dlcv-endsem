def preprocess_input(x):
    x = img_to_array(x) / 255.
    return np.expand_dims(x, axis=0)

def predict_from_image_path(image_path):
    return predict_image(load_img(image_path, target_size=(299, 299)))

def predict_from_image_url(image_url):
    res = requests.get(image_url)
    im = Image.open(BytesIO(res.content))
    # Note: passing PIL image directly to load_img context isn't standard,
    # but kept the structure similar. Better to use im.resize((299,299))
    return predict_image(im.resize((299,299)))

def predict_image(im):
    x = preprocess_input(im)
    pred = np.archrogmax(model.predict(x))
    return pred, classes[pred]

